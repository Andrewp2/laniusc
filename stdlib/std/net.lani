// Source-level networking host ABI declarations.
// The service contract below is intentionally conservative: the current
// backends can type-check these declarations, but they do not bind networking.

module std::net;

pub type NetworkCapability = bool;
pub type NetworkRuntimeAbiVersion = u32;
pub type NetworkServiceId = u32;
pub type NetworkServiceStatus = u32;
pub type NetworkOperationResult = i32;

pub const NETWORK_RUNTIME_ABI_VERSION: NetworkRuntimeAbiVersion = 1;
pub const NETWORK_SERVICE_ID: NetworkServiceId = 5;
pub const NETWORK_SERVICE_STATUS_UNAVAILABLE: NetworkServiceStatus = 1;
pub const NETWORK_HAS_RUNTIME_BINDING: NetworkCapability = false;
pub const NETWORK_OPERATION_OK: NetworkOperationResult = 0;
pub const NETWORK_OPERATION_UNAVAILABLE: NetworkOperationResult = -1;

pub fn network_runtime_abi_version() -> NetworkRuntimeAbiVersion {
    return NETWORK_RUNTIME_ABI_VERSION;
}

pub fn network_service_id() -> NetworkServiceId {
    return NETWORK_SERVICE_ID;
}

pub fn network_service_is_known() -> NetworkCapability {
    return true;
}

pub fn network_contract_metadata_is_available() -> NetworkCapability {
    return network_service_is_known();
}

pub fn network_service_status() -> NetworkServiceStatus {
    return NETWORK_SERVICE_STATUS_UNAVAILABLE;
}

pub fn network_is_available() -> NetworkCapability {
    return NETWORK_HAS_RUNTIME_BINDING;
}

pub fn network_is_blocked() -> NetworkCapability {
    return !network_is_available();
}

pub fn network_is_known_but_unbound() -> NetworkCapability {
    return network_service_is_known() && network_is_blocked();
}

pub fn network_requires_runtime_binding() -> NetworkCapability {
    return !NETWORK_HAS_RUNTIME_BINDING;
}

pub fn network_host_abi_is_contract_only() -> NetworkCapability {
    return network_requires_runtime_binding();
}

pub fn network_operation_ok() -> NetworkOperationResult {
    return NETWORK_OPERATION_OK;
}

pub fn network_operation_unavailable() -> NetworkOperationResult {
    return NETWORK_OPERATION_UNAVAILABLE;
}

pub fn network_operation_succeeded(result: NetworkOperationResult) -> NetworkCapability {
    return result >= 0;
}

pub fn network_operation_failed(result: NetworkOperationResult) -> NetworkCapability {
    return result < 0;
}

pub fn network_operation_is_unavailable(result: NetworkOperationResult) -> NetworkCapability {
    return result == NETWORK_OPERATION_UNAVAILABLE;
}

pub fn network_operation_is_fail_closed(result: NetworkOperationResult) -> NetworkCapability {
    return network_is_known_but_unbound() && network_operation_is_unavailable(result);
}

pub fn tcp_api_is_executable() -> NetworkCapability {
    return NETWORK_HAS_RUNTIME_BINDING;
}

pub fn tcp_api_is_blocked() -> NetworkCapability {
    return !tcp_api_is_executable();
}

pub fn tcp_api_is_known_but_unbound() -> NetworkCapability {
    return network_service_is_known() && tcp_api_is_blocked();
}

pub fn tcp_api_requires_runtime_binding() -> NetworkCapability {
    return !tcp_api_is_executable();
}

pub fn tcp_connect_is_executable() -> NetworkCapability {
    return tcp_api_is_executable();
}

pub fn tcp_connect_is_blocked() -> NetworkCapability {
    return !tcp_connect_is_executable();
}

pub fn tcp_connect_is_known_but_unbound() -> NetworkCapability {
    return network_service_is_known() && tcp_connect_is_blocked();
}

pub fn tcp_connect_requires_runtime_binding() -> NetworkCapability {
    return !tcp_connect_is_executable();
}

pub fn tcp_bind_is_executable() -> NetworkCapability {
    return tcp_api_is_executable();
}

pub fn tcp_bind_is_blocked() -> NetworkCapability {
    return !tcp_bind_is_executable();
}

pub fn tcp_bind_is_known_but_unbound() -> NetworkCapability {
    return network_service_is_known() && tcp_bind_is_blocked();
}

pub fn tcp_bind_requires_runtime_binding() -> NetworkCapability {
    return !tcp_bind_is_executable();
}

