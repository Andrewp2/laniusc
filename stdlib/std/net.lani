    return tcp_api_is_executable();
}

pub fn tcp_send_is_blocked() -> NetworkCapability {
    return !tcp_send_is_executable();
}

pub fn tcp_send_is_known_but_unbound() -> NetworkCapability {
    return network_service_is_known() && tcp_send_is_blocked();
}

pub fn tcp_send_requires_runtime_binding() -> NetworkCapability {
    return !tcp_send_is_executable();
}

pub fn tcp_recv_is_executable() -> NetworkCapability {
    return tcp_api_is_executable();
}

pub fn tcp_recv_is_blocked() -> NetworkCapability {
    return !tcp_recv_is_executable();
}

pub fn tcp_recv_is_known_but_unbound() -> NetworkCapability {
    return network_service_is_known() && tcp_recv_is_blocked();
}

pub fn tcp_recv_requires_runtime_binding() -> NetworkCapability {
    return !tcp_recv_is_executable();
