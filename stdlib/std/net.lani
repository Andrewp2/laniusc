pub fn tcp_listen_is_known_but_unbound() -> NetworkCapability {
    return network_service_is_known() && tcp_listen_is_blocked();
}

pub fn tcp_listen_requires_runtime_binding() -> NetworkCapability {
    return !tcp_listen_is_executable();
}

