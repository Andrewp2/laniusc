    return tcp_api_is_executable();
}

pub fn tcp_accept_is_blocked() -> NetworkCapability {
    return !tcp_accept_is_executable();
}

pub fn tcp_accept_is_known_but_unbound() -> NetworkCapability {
    return network_service_is_known() && tcp_accept_is_blocked();
}

pub fn tcp_accept_requires_runtime_binding() -> NetworkCapability {
    return !tcp_accept_is_executable();
}

pub fn tcp_close_is_executable() -> NetworkCapability {
    return tcp_api_is_executable();
}

pub fn tcp_close_is_blocked() -> NetworkCapability {
    return !tcp_close_is_executable();
}

pub fn tcp_close_is_known_but_unbound() -> NetworkCapability {
    return network_service_is_known() && tcp_close_is_blocked();
}

pub fn tcp_close_requires_runtime_binding() -> NetworkCapability {
