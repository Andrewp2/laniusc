// Source-level environment variable host ABI declarations.

module std::env;

pub extern "lanius_std" fn var_len(key_ptr: u32, key_len: usize) -> i32;

pub extern "lanius_std" fn var_read(
    key_ptr: u32,
    key_len: usize,
    value_ptr: u32,
    value_len: usize,
) -> i32;

pub extern "lanius_std" fn var_count() -> i32;

pub extern "lanius_std" fn var_key_len(index: i32) -> i32;

pub extern "lanius_std" fn var_key_read(index: i32, ptr: u32, len: usize) -> i32;
