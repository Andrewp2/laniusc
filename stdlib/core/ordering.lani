// Declaration seed for comparison ordering.

module core::ordering;

pub enum Ordering {
    Less,
    Equal,
    Greater,
}

pub fn compare_i32(left: i32, right: i32) -> Ordering {
    if (left < right) {
        return Less;
    } else {
        if (left > right) {
            return Greater;
        } else {
            return Equal;
        }
    }
}
