module app::main;

import core::f32;
import std::vec;

extern "lanius_std" fn open_read_path(path: str) -> i32;
extern "lanius_std" fn open_write_path(path: str) -> i32;
extern "lanius_std" fn read_i32(handle: i32, fallback: i32) -> i32;
extern "lanius_std" fn write_text(handle: i32, text: str) -> i32;
extern "lanius_std" fn write_i32(handle: i32, value: i32) -> i32;
extern "lanius_std" fn write_byte(handle: i32, value: i32) -> i32;
extern "lanius_std" fn write_newline(handle: i32) -> i32;
extern "lanius_std" fn close_file(handle: i32) -> i32;
extern "lanius_std" fn i32_to_f32(value: i32) -> f32;

struct Vec3 {
    x: f32,
    y: f32,
    z: f32,
}

impl Vec3 {
    fn new(x: f32, y: f32, z: f32) -> Vec3 {
        return Vec3 { x: x, y: y, z: z };
    }

    fn add(self, right: Vec3) -> Vec3 {
        return Vec3::new(self.x + right.x, self.y + right.y, self.z + right.z);
    }

    fn sub(self, right: Vec3) -> Vec3 {
        return Vec3::new(self.x - right.x, self.y - right.y, self.z - right.z);
    }

    fn mul_scalar(self, scale: f32) -> Vec3 {
        return Vec3::new(self.x * scale, self.y * scale, self.z * scale);
    }

    fn dot(self, right: Vec3) -> f32 {
        return self.x * right.x + self.y * right.y + self.z * right.z;
    }

    fn length(self) -> f32 {
        return core::f32::sqrt(self.dot(self));
    }

    fn unit(self) -> Vec3 {
        let len: f32 = self.length();
        if (len == 0.0) {
            return self;
        }
        return self.mul_scalar(1.0 / len);
    }

    fn lerp(self, right: Vec3, t: f32) -> Vec3 {
        return self.mul_scalar(1.0 - t).add(right.mul_scalar(t));
    }
}

struct Ray {
    origin: Vec3,
    direction: Vec3,
}

impl Ray {
    fn at(self, t: f32) -> Vec3 {
        return self.origin.add(self.direction.mul_scalar(t));
    }
}

struct Camera {
    origin: Vec3,
    lower_left_corner: Vec3,
    horizontal: Vec3,
    vertical: Vec3,
}

impl Camera {
    fn ray(self, u: f32, v: f32) -> Ray {
        let across: Vec3 = self.horizontal.mul_scalar(u);
        let up: Vec3 = self.vertical.mul_scalar(v);
        let target: Vec3 = self.lower_left_corner.add(across).add(up);
        return Ray {
            origin: self.origin,
            direction: target.sub(self.origin),
        };
    }
}

struct Sphere {
    center: Vec3,
    radius: f32,
    albedo: Vec3,
}

struct Hit {
    ok: bool,
    t: f32,
    point: Vec3,
    normal: Vec3,
    albedo: Vec3,
}

struct RenderSettings {
    width: i32,
    height: i32,
    samples_per_pixel: i32,
}

fn miss() -> Hit {
    return Hit {
        ok: false,
        t: 0.0,
        point: Vec3::new(0.0, 0.0, 0.0),
        normal: Vec3::new(0.0, 0.0, 0.0),
        albedo: Vec3::new(0.0, 0.0, 0.0),
    };
}

fn hit_sphere(sphere: Sphere, ray: Ray, t_min: f32, t_max: f32) -> Hit {
    let oc: Vec3 = ray.origin.sub(sphere.center);
    let a: f32 = ray.direction.dot(ray.direction);
    let half_b: f32 = oc.dot(ray.direction);
    let c: f32 = oc.dot(oc) - sphere.radius * sphere.radius;
    let discriminant: f32 = half_b * half_b - a * c;
    if (discriminant < 0.0) {
        return miss();
    }

    let sqrtd: f32 = core::f32::sqrt(discriminant);
    let root: f32 = (-half_b - sqrtd) / a;
    if (root < t_min || root > t_max) {
        root = (-half_b + sqrtd) / a;
        if (root < t_min || root > t_max) {
            return miss();
        }
    }

    let point: Vec3 = ray.at(root);
    let outward_normal: Vec3 = point.sub(sphere.center).mul_scalar(1.0 / sphere.radius);
    return Hit {
        ok: true,
        t: root,
        point: point,
        normal: outward_normal.unit(),
        albedo: sphere.albedo,
    };
}

fn hit_world(world: std::vec::Vec<Sphere>, ray: Ray) -> Hit {
    let closest_so_far: f32 = 1000000.0;
    let result: Hit = miss();

    for sphere in world {
        let hit: Hit = hit_sphere(sphere, ray, 0.001, closest_so_far);
        if (hit.ok) {
            closest_so_far = hit.t;
            result = hit;
        }
    }

    return result;
}

fn sky_color(ray: Ray) -> Vec3 {
    let dir: Vec3 = ray.direction.unit();
    let t: f32 = 0.5 * (dir.y + 1.0);
    return Vec3::new(1.0, 1.0, 1.0).lerp(Vec3::new(0.5, 0.7, 1.0), t);
}

fn ray_color(ray: Ray, world: std::vec::Vec<Sphere>) -> Vec3 {
    let hit: Hit = hit_world(world, ray);
    if (hit.ok) {
        let light_dir: Vec3 = Vec3::new(-0.4, 0.9, -0.6).unit();
        let diffuse: f32 = hit.normal.dot(light_dir);
        let shade: f32 = 0.18;
        if (diffuse > 0.0) {
            shade = shade + 0.82 * diffuse;
        }
        return hit.albedo.mul_scalar(shade);
    }
    return sky_color(ray);
}

fn make_camera(settings: RenderSettings) -> Camera {
    let aspect_ratio: f32 = i32_to_f32(settings.width) / i32_to_f32(settings.height);
    let viewport_height: f32 = 2.0;
    let viewport_width: f32 = aspect_ratio * viewport_height;
    let focal_length: f32 = 1.0;
    let origin: Vec3 = Vec3::new(0.0, 0.0, 0.0);
    let horizontal: Vec3 = Vec3::new(viewport_width, 0.0, 0.0);
    let vertical: Vec3 = Vec3::new(0.0, viewport_height, 0.0);
    let lower_left_corner: Vec3 = origin
        .sub(horizontal.mul_scalar(0.5))
        .sub(vertical.mul_scalar(0.5))
        .sub(Vec3::new(0.0, 0.0, focal_length));
    return Camera {
        origin: origin,
        lower_left_corner: lower_left_corner,
        horizontal: horizontal,
        vertical: vertical,
    };
}

fn default_settings() -> RenderSettings {
    return RenderSettings {
        width: 16,
        height: 9,
        samples_per_pixel: 1,
    };
}

fn sanitize_settings(settings: RenderSettings) -> RenderSettings {
    let width: i32 = settings.width;
    let height: i32 = settings.height;
    let samples_per_pixel: i32 = settings.samples_per_pixel;
    if (width < 2) {
        width = 2;
    }
    if (height < 2) {
        height = 2;
    }
    if (samples_per_pixel < 1) {
        samples_per_pixel = 1;
    }
    return RenderSettings {
        width: width,
        height: height,
        samples_per_pixel: samples_per_pixel,
    };
}

fn load_settings(path: str) -> RenderSettings {
    let fallback: RenderSettings = default_settings();
    let file: i32 = open_read_path(path);
    if (file < 0) {
        return fallback;
    }

    let width: i32 = read_i32(file, fallback.width);
    let height: i32 = read_i32(file, fallback.height);
    let samples_per_pixel: i32 = read_i32(file, fallback.samples_per_pixel);
    close_file(file);
    return sanitize_settings(RenderSettings {
        width: width,
        height: height,
        samples_per_pixel: samples_per_pixel,
    });
}

fn make_world() -> std::vec::Vec<Sphere> {
    let world: std::vec::Vec<Sphere> = std::vec::Vec<Sphere>::new();

    world.push(Sphere {
        center: Vec3::new(0.0, -100.5, -1.0),
        radius: 100.0,
        albedo: Vec3::new(0.8, 0.8, 0.0),
    });
    world.push(Sphere {
        center: Vec3::new(0.0, 0.0, -1.0),
        radius: 0.5,
        albedo: Vec3::new(0.7, 0.3, 0.3),
    });
    world.push(Sphere {
        center: Vec3::new(1.0, 0.0, -1.6),
        radius: 0.5,
        albedo: Vec3::new(0.2, 0.4, 0.8),
    });

    return world;
}

fn operation_failed(result: i32) -> bool {
    return result < 0;
}

fn write_space(file: i32) -> i32 {
    return write_byte(file, 32);
}

fn write_header(file: i32, settings: RenderSettings) -> i32 {
    if (operation_failed(write_text(file, "P3"))) {
        return -1;
    }
    if (operation_failed(write_newline(file))) {
        return -1;
    }
    if (operation_failed(write_i32(file, settings.width))) {
        return -1;
    }
    if (operation_failed(write_space(file))) {
        return -1;
    }
    if (operation_failed(write_i32(file, settings.height))) {
        return -1;
    }
    if (operation_failed(write_newline(file))) {
        return -1;
    }
    if (operation_failed(write_text(file, "255"))) {
        return -1;
    }
    return write_newline(file);
}

fn clamp01(value: f32) -> f32 {
    if (value < 0.0) {
        return 0.0;
    }
    if (value > 0.999) {
        return 0.999;
    }
    return value;
}

fn linear_to_gamma(value: f32) -> f32 {
    return core::f32::sqrt(clamp01(value));
}

fn color_to_byte(value: f32) -> i32 {
    let scaled: f32 = linear_to_gamma(value) * 256.0;
    let byte: i32 = 0;
    let threshold: f32 = 1.0;
    while (threshold <= scaled && byte < 255) {
        byte += 1;
        threshold += 1.0;
    }
    return byte;
}

fn write_color(file: i32, color: Vec3) -> i32 {
    let r: i32 = color_to_byte(color.x);
    let g: i32 = color_to_byte(color.y);
    let b: i32 = color_to_byte(color.z);
    if (operation_failed(write_i32(file, r))) {
        return -1;
    }
    if (operation_failed(write_space(file))) {
        return -1;
    }
    if (operation_failed(write_i32(file, g))) {
        return -1;
    }
    if (operation_failed(write_space(file))) {
        return -1;
    }
    if (operation_failed(write_i32(file, b))) {
        return -1;
    }
    return write_newline(file);
}

fn pixel_color(
    camera: Camera,
    world: std::vec::Vec<Sphere>,
    settings: RenderSettings,
    x: i32,
    y: i32,
) -> Vec3 {
    let samples: i32 = settings.samples_per_pixel;
    let samples_f: f32 = i32_to_f32(samples);
    let color: Vec3 = Vec3::new(0.0, 0.0, 0.0);

    for sample_y in 0..samples {
        for sample_x in 0..samples {
            let x_offset: f32 = (i32_to_f32(sample_x) + 0.5) / samples_f;
            let y_offset: f32 = (i32_to_f32(sample_y) + 0.5) / samples_f;
            let u: f32 = (i32_to_f32(x) + x_offset) / i32_to_f32(settings.width - 1);
            let row_from_top: i32 = settings.height - 1 - y;
            let v: f32 =
                (i32_to_f32(row_from_top) + y_offset) / i32_to_f32(settings.height - 1);
            color = color.add(ray_color(camera.ray(u, v), world));
        }
    }

    return color.mul_scalar(1.0 / (samples_f * samples_f));
}

fn render(file: i32, settings: RenderSettings) -> i32 {
    if (operation_failed(write_header(file, settings))) {
        return -1;
    }

    let camera: Camera = make_camera(settings);
    let world: std::vec::Vec<Sphere> = make_world();
    let pixel_count: i32 = 0;

    for y in 0..settings.height {
        for x in 0..settings.width {
            let color: Vec3 = pixel_color(camera, world, settings, x, y);
            if (operation_failed(write_color(file, color))) {
                return -1;
            }
            pixel_count += 1;
        }
    }

    return pixel_count;
}

fn main() -> i32 {
    let settings: RenderSettings = load_settings("render_settings.txt");
    let file: i32 = open_write_path("lanius_ray.ppm");
    if (file < 0) {
        print(-1);
        return 1;
    }

    let pixels_written: i32 = render(file, settings);
    let close_status: i32 = close_file(file);
    if (operation_failed(pixels_written) || operation_failed(close_status)) {
        print(-2);
        return 1;
    }

    print(pixels_written);
    return 0;
}
