fn abs_i32(value: i32) -> i32 {
    if (value < 0) {
        return -value;
    } else {
        return value;
    }
}

fn distance_weight(dx: i32, dy: i32) -> i32 {
    let ax: i32 = abs_i32(dx);
    let ay: i32 = abs_i32(dy);
    let dist: i32 = ax + ay;
    let weight: i32 = 64 - dist;
    if (weight < 0) {
        return 0;
    } else {
        return weight;
    }
}

fn grid_value(x: i32, y: i32) -> i32 {
    let scaled_x: i32 = x * 16;
    let scaled_y: i32 = y * 16;
    let dx: i32 = scaled_x - 24;
    let dy: i32 = scaled_y - 24;
    return distance_weight(dx, dy);
}

fn grid_checksum() -> i32 {
    let y: i32 = 0;
    let checksum: i32 = 0;
    while (y < 4) {
        let x: i32 = 0;
        while (x < 4) {
            checksum += grid_value(x, y);
            x += 1;
        }
        y += 1;
    }
    return checksum;
}

fn main() {
    let checksum: i32 = grid_checksum();
    if (checksum == 512) {
        return 0;
    } else {
        return 1;
    }
}
