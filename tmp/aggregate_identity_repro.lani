struct Vec3 {
    x: f32,
    y: f32,
    z: f32,
}

fn keep(value: Vec3) -> Vec3 {
    return value;
}

fn main() {
    let input: Vec3 = Vec3 { x: 0.5, y: 0.7, z: 1.0 };
    let output: Vec3 = keep(input);
    if (!(output.x > 0.49 && output.x < 0.51)) {
        return 1;
    }
    if (!(output.y > 0.69 && output.y < 0.71)) {
        return 2;
    }
    if (!(output.z > 0.99 && output.z < 1.01)) {
        return 3;
    }
    return 0;
}
