{
  "lanius_daemon": [
    "target/release/laniusc",
    "daemon",
    "--stdio",
    "--backend",
    "x86_64",
    "--stdlib-root",
    "stdlib"
  ],
  "o0": {
    "c": [
      "gcc",
      "-O0",
      "-g0",
      "{source}",
      "-o",
      "{output}"
    ],
    "cpp": [
      "g++",
      "-O0",
      "-g0",
      "{source}",
      "-o",
      "{output}"
    ],
    "rust": [
      "rustc",
      "-C",
      "opt-level=0",
      "-C",
      "debuginfo=0",
      "-C",
      "strip=debuginfo",
      "{source}",
      "-o",
      "{output}"
    ],
    "zig": [
      "zig",
      "build-exe",
      "-lc",
      "-O",
      "Debug",
      "-fstrip",
      "{source}",
      "-femit-bin={output}"
    ]
  },
  "optimized": {
    "c": [
      "gcc",
      "-O2",
      "-g0",
      "{source}",
      "-o",
      "{output}"
    ],
    "cpp": [
      "g++",
      "-O2",
      "-g0",
      "{source}",
      "-o",
      "{output}"
    ],
    "rust": [
      "rustc",
      "-C",
      "opt-level=3",
      "-C",
      "debuginfo=0",
      "-C",
      "strip=debuginfo",
      "{source}",
      "-o",
      "{output}"
    ],
    "zig": [
      "zig",
      "build-exe",
      "-lc",
      "-O",
      "ReleaseFast",
      "-fstrip",
      "{source}",
      "-femit-bin={output}"
    ]
  },
  "schema": "lanius.compile-scaling-command-templates.v1"
}
